---
import '@/styles/global.css';
import QuizCv from '@/components/QuizCv';
import Header from '@/components/Header';
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Générer votre CV — CVClair</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (function(){var t=localStorage.getItem('cvclair-theme');if(!t)t=matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';document.documentElement.setAttribute('data-theme',t);})();
    </script>
  </head>
  <body>
    <Header client:load />
    <QuizCv client:only="react" />
  </body>
</html>
