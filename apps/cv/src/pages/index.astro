---
import '@/styles/global.css';
import ThemeToggle from '@/components/ThemeToggle';
import DemoInteractive from '@/components/DemoInteractive';
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CVClair — Le CV français qui passe les ATS</title>
    <meta name="description" content="Créez un CV français testé contre les parseurs ATS. Gabarits prouvés, IA qui n'invente rien, données chez vous." />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (function(){var t=localStorage.getItem('cvclair-theme');if(!t)t=matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';document.documentElement.setAttribute('data-theme',t);})();
    </script>
  </head>
  <body>
    <header class="header">
      <a href="/" class="header-logo">CV<span>Clair</span></a>
      <nav class="header-nav">
        <a href="/app/quiz/">Créer mon CV</a>
        <ThemeToggle client:load />
      </nav>
    </header>

    <main>
      <section class="accueil-hero">
        <h1>Votre CV, enfin ATS-proof.</h1>
        <p>Créez gratuitement un CV français. L'IA le rédige pour vous — sans rien inventer. Testé contre 20 règles ATS, prouvé sur 10 profils témoins.</p>
        <a class="bouton" href="/app/quiz/">Essayer maintenant — c'est gratuit</a>
        <div class="accueil-sous">
          <span>Aucune carte bancaire</span>
          <span>Données restent chez vous</span>
        </div>
      </section>

      <DemoInteractive client:load />

      <section class="badges">
        <div class="badge">
          <div class="badge-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          ATS testé sur 10 profils
        </div>
        <div class="badge">
          <div class="badge-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          IA qui n'invente rien
        </div>
        <div class="badge">
          <div class="badge-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          Données locales
        </div>
      </section>

      <h2 class="section-titre">Comment ça marche</h2>
      <section class="atouts">
        <div class="atout">
          <h3>1. Répondez au quiz</h3>
          <p>5 questions sur votre expérience. 2 minutes chrono.</p>
        </div>
        <div class="atout">
          <h3>2. L'IA rédige</h3>
          <p>Elle reformule vos réponses — sans inventer. Le garde-fou vérifie chaque mot.</p>
        </div>
        <div class="atout">
          <h3>3. Téléchargez</h3>
          <p>PDF texte sélectionnable. Score ATS en direct. Gabarits prouvés.</p>
        </div>
      </section>

      <h2 class="section-titre">Tarifs transparents</h2>
      <section class="tarifs tarifs-deux">
        <div class="tarif">
          <h3>Gratuit</h3>
          <div class="prix">0 €</div>
          <ul>
            <li>Création complète du CV</li>
            <li>3 gabarits ATS de base</li>
            <li>Aperçu fidèle à l'écran</li>
            <li>Score ATS de structure</li>
            <li>3 générations IA offertes</li>
          </ul>
          <a class="bouton secondary" href="/app/quiz/">Commencer</a>
        </div>
        <div class="tarif mis-en-avant">
          <h3>Pro</h3>
          <div class="prix">7,99 € <small>/ mois, ou 59 €/an</small></div>
          <ul>
            <li>PDF + DOCX illimités</li>
            <li>IA illimitée + adaptation à l'offre</li>
            <li>Score ATS complet</li>
            <li>Lettre de motivation générée</li>
            <li>Synchronisation chiffrée</li>
          </ul>
          <a class="bouton" href="/app/quiz/">Découvrir</a>
        </div>
      </section>

      <footer class="accueil-pied">
        <p>CVClair — gabarits vérifiés par harnais automatisé.<br/>« Testé contre les parseurs », jamais « garanti ».</p>
      </footer>
    </main>
  </body>
</html>
