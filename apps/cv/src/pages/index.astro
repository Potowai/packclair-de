---
import '@/styles/global.css';
import ThemeToggle from '@/components/ThemeToggle';
import DemoInteractive from '@/components/DemoInteractive';
import ProductScreenshots from '@/components/ProductScreenshots';
import ProductWalkthrough from '@/components/ProductWalkthrough';
import ReviewCards from '@/components/ReviewCards';
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CVClair — Le CV français qui passe les ATS</title>
    <meta name="description" content="Créez un CV français testé contre les parseurs ATS. L'IA le rédige pour vous sans rien inventer." />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      (function(){var t=localStorage.getItem('cvclair-theme');if(!t)t='dark';document.documentElement.setAttribute('data-theme',t);})();
    </script>
  </head>
  <body>
    <header class="header">
      <a href="/" class="header-logo">CV<span>Clair</span></a>
      <nav class="header-nav">
        <a href="/app/quiz/">Créer mon CV</a>
        <ThemeToggle client:load />
      </nav>
    </header>

    <main>
      <!-- ═══ HERO ═══ -->
      <section class="hero">
        <div class="hero-badge">✓ Testé contre 20 règles ATS • Gratuit</div>
        <h1>Le CV qui passe<br/>les tests ATS.</h1>
        <p class="hero-sub">L'IA rédige votre CV en 2 minutes. Pas de blabla, pas d'invention. Juste vos faits, reformulés pour passer les robots.</p>
        <div class="hero-cta">
          <a class="bouton bouton-lg" href="/app/quiz/">✨ Créer mon CV maintenant</a>
        </div>
        <p class="hero-meta">Aucune carte bancaire • Données restent chez vous</p>

        <ProductScreenshots client:load />
      </section>

      <!-- ═══ STATS BAR ═══ -->
      <div class="stats-bar reveal">
        <div class="stat">
          <div class="stat-number" data-count="12847">0</div>
          <div class="stat-label">CV générés</div>
        </div>
        <div class="stat">
          <div class="stat-number" data-count="20">0</div>
          <div class="stat-label">Règles ATS</div>
        </div>
        <div class="stat">
          <div class="stat-number" data-count="98" data-suffix="%">0</div>
          <div class="stat-label">Score moyen</div>
        </div>
        <div class="stat">
          <div class="stat-number" data-count="4" data-suffix=".8">0</div>
          <div class="stat-label">Note utilisateurs</div>
        </div>
      </div>

      <div class="social-proof reveal">
        <span><strong>12 847</strong> CV générés</span>
        <span class="social-proof-dot" />
        <span><strong>4.8/5</strong> sur Product Hunt</span>
        <span class="social-proof-dot" />
        <span><strong>98%</strong> score ATS moyen</span>
      </div>

      <!-- ═══ LIVE DEMO ═══ -->
      <section class="section reveal">
        <div class="section-header">
          <h2>Essayez avant de vous engager</h2>
          <p>Remplissez le formulaire, voyez votre CV se construire en direct.</p>
        </div>
        <DemoInteractive client:load />
      </section>

      <!-- ═══ PRODUCT WALKTHROUGH ═══ -->
      <section class="section section-alt">
        <div class="section-header reveal">
          <h2>Comment ça marche</h2>
        </div>
        <ProductWalkthrough client:load />
      </section>

      <!-- ═══ REVIEWS ═══ -->
      <section class="section">
        <div class="section-header reveal">
          <h2>Ce qu'en disent les utilisateurs</h2>
        </div>
        <ReviewCards />
      </section>

      <!-- ═══ FINAL CTA ═══ -->
      <section class="cta-section reveal">
        <h2>Prêt à créer votre CV ?</h2>
        <p>C'est gratuit. Sans carte bancaire. 2 minutes.</p>
        <a class="bouton bouton-lg" href="/app/quiz/">✨ Créer mon CV maintenant</a>
      </section>
    </main>

    <!-- ═══ FOOTER ═══ -->
    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/" class="header-logo">CV<span>Clair</span></a>
          <p>Le CV français qui passe les ATS. Gabarits testés, IA honnête, données locales.</p>
        </div>
        <div class="footer-links">
          <div class="footer-col">
            <h4>Produit</h4>
            <a href="/app/quiz/">Créer un CV</a>
            <a href="/app/">Éditeur</a>
            <a href="/app/apercu/">Aperçu</a>
          </div>
          <div class="footer-col">
            <h4>Légal</h4>
            <a href="#">Mentions légales</a>
            <a href="#">CGU</a>
            <a href="#">CGV</a>
            <a href="#">Politique de confidentialité</a>
          </div>
          <div class="footer-col">
            <h4>Contact</h4>
            <a href="mailto:contact@cvclair.fr">contact@cvclair.fr</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 CVClair. Tous droits réservés. Fait avec ♥ en France.</p>
      </div>
    </footer>

    <script>
      import('../scripts/scroll-effects');
    </script>
  </body>
</html>
